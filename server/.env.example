# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ipl_dashboard?retryWrites=true&w=majority

# Admin API token (generate a secure random string)
ADMIN_TOKEN=your-secure-admin-token-here

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
